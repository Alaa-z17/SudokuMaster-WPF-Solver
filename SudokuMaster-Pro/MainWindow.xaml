<Window x:Class="SudokuMaster_Pro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sudoku Master Pro" 
        Height="780" Width="700"
        MinHeight="700" MinWidth="650"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F9"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Icon="Assets/sodoko.ico">

    <Window.Resources>
        <!-- Rounded corners style for buttons -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Sudoku cells -->
        <Style x:Key="SudokuCell" TargetType="TextBox">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0.5"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="#D4E6F1"/>
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/>   <!-- Timer & Best Score -->
            <RowDefinition Height="Auto"/>   <!-- Title text -->
            <RowDefinition Height="*"/>      <!-- Sudoku grid -->
            <RowDefinition Height="Auto"/>   <!-- Buttons panel -->
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Border Background="#2C3E50" Grid.Row="0" Height="36" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="Sudoku Master Pro" Foreground="White" FontSize="16" 
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Name="btnMinimize" Content="─" Width="30" Height="30" 
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            Click="btnMinimize_Click" Cursor="Hand"/>
                    <Button Name="btnClose" Content="✕" Width="30" Height="30" 
                            Background="Transparent" Foreground="White" BorderThickness="0"
                            Click="btnClose_Click" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Timer & Best Score Panel -->
        <Border Grid.Row="1" Background="White" Margin="20,15,20,10" CornerRadius="12" 
                Padding="12,8" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Timer -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left">
                    <TextBlock Text="⏱️" FontSize="22" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Name="txtTimer" Text="00:00" FontSize="24" FontWeight="Bold" 
                               Foreground="#E67E22" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Music control button -->
                <Button Name="btnMusicToggle" Grid.Column="1" Width="40" Height="40" 
                        Style="{StaticResource ModernButton}" Background="#3498DB"
                        Click="btnMusicToggle_Click" FontSize="18" Padding="0">
                    <TextBlock Text="🔊" Name="musicIcon"/>
                </Button>

                <!-- Best Score -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="🏆" FontSize="22" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Name="txtBestScore" Text="Best: --:--" FontSize="18" 
                               FontWeight="Bold" Foreground="#27AE60" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Title -->
        <TextBlock Text="SUDOKU MASTER" 
                   FontSize="32" FontWeight="ExtraBold" Foreground="#2C3E50"
                   HorizontalAlignment="Center" Margin="0,5,0,10" Grid.Row="2"
                   Opacity="0.9"/>

        <!-- Sudoku grid border (adjusted to ensure all cells visible) -->
        <Border BorderBrush="#2C3E50" BorderThickness="3" CornerRadius="8" Grid.Row="3" 
                HorizontalAlignment="Center" VerticalAlignment="Top" 
                Background="White" Margin="20,10,20,25">
            <Grid Name="MainSudokuGrid" Width="450" Height="450">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
            </Grid>
        </Border>

        <!-- Buttons panel -->
        <WrapPanel Grid.Row="4" HorizontalAlignment="Center" Margin="20,15,20,20" 
                   VerticalAlignment="Top">
            <ComboBox Name="cmbDifficulty" Width="100" Height="38" Margin="5" 
                      Background="White" BorderBrush="#BDC3C7" SelectedIndex="1"
                      FontSize="13">
                <ComboBoxItem Content="Easy" Tag="40"/>
                <ComboBoxItem Content="Medium" Tag="45"/>
                <ComboBoxItem Content="Hard" Tag="55"/>
            </ComboBox>

            <Button Name="btnGenerate" Content="🔄 New" Style="{StaticResource ModernButton}" 
                    Background="#3498DB" Margin="5" Click="btnGenerate_Click"/>
            <Button Name="btnCheck" Content="✓ Check" Style="{StaticResource ModernButton}" 
                    Background="#F39C12" Margin="5" Click="btnCheck_Click"/>
            <Button Name="btnHint" Content="💡 Hint" Style="{StaticResource ModernButton}" 
                    Background="#9B59B6" Margin="5" Click="btnHint_Click"/>
            <Button Name="btnSolve" Content="⚡ Solve" Style="{StaticResource ModernButton}" 
                    Background="#2ECC71" Margin="5" Click="btnSolve_Click"/>
            <Button Name="btnClear" Content="🗑 Clear" Style="{StaticResource ModernButton}" 
                    Background="#E74C3C" Margin="5" Click="btnClear_Click"/>
        </WrapPanel>

        <!-- MediaElement for background music (hidden) -->
        <MediaElement Name="bgMusic" LoadedBehavior="Manual" UnloadedBehavior="Stop" 
                      Volume="0.5" Visibility="Collapsed" MediaFailed="bgMusic_MediaFailed"/>
    </Grid>
</Window>